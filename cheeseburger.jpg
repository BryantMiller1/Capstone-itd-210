            <h3>Chicken Tenders</h3>
            <p>Battered fried chicken tenders</p>
            <a class="card-link" href="menu.html">Order →</a>
          </div>
        </article>

         <!-- CARD 5 -->
        <article class="card" id="contact">
          <div class="card-media">
            <img src="images/classic burger.jpg" alt="AI image of burger from Canva">
          </div>
          <div class="card-body">
            <span class="card-tag">Burger</span>
            <h3>Cheeseburger</h3>
            <p>Classic burger</p>
            <a class="card-link" href="menu.html">Order →</a>
          </div>
        </article>

          <!-- CARD 6 -->
        <article class="card" id="contact">
          <div class="card-media">
            <img src="images/hotdog.jpg" alt="AI image of hot dog from Canva">
          </div>
          <div class="card-body">
            <span class="card-tag">Hotdog</span>
            <h3>Plain Hotdog</h3>
            <p>Beef dog</p>
            <a class="card-link" href="menu.html">Order →</a>
          </div>
        </article>

          <!-- CARD 7 -->
        <article class="card" id="contact">
          <div class="card-media">
            <img src="images/wings.jpg" alt="AI image of wings from Canva">
          </div>
          <div class="card-body">
            <span class="card-tag">Chicken</span>
            <h3>Wings</h3>
            <p>Fried wings</p>
            <a class="card-link" href="menu.html">Order →</a>
          </div>
        </article>

          <!-- CARD 8 -->
        <article class="card" id="contact">
          <div class="card-media">
            <img src="images/soda.jpg" alt="AI image of soda from Canva">
          </div>
          <div class="card-body">
            <span class="card-tag">Drink</span>
            <h3>Soda</h3>
